# ===================================================
# Sand Availability Notifier & AI Agent Configuration
# ===================================================

# Target Web Portal URL
TARGET_URL=https://tgmiv.cgg.gov.in/home

# Comma-separated location keywords (English and Telugu supported)
# Strictly for Karimnagar District, Saidapur Mandal, Elabotharam Village:
KEYWORDS=Karimnagar,కరీంనగర్,Saidapur,సైదాపూర్,Elabotharam,ఎలబోతారం,Lingapur,లింగాపూర్,Korekal,కోరేకల్

# Monitoring Polling Interval in seconds (default: 300 seconds / 5 minutes)
# Set to 60-120 seconds during peak slot announcement times (~3:00 PM)
CHECK_INTERVAL_SECONDS=300

# File path for deduplication cache
CACHE_FILE=seen_updates.json

# ---------------------------------------------------
# Telegram Notification Settings
# ---------------------------------------------------
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---------------------------------------------------
# Email SMTP Notification Settings
# ---------------------------------------------------
ENABLE_EMAIL=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_TO=recipient_email@gmail.com
